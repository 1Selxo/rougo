[core]
	repositoryformatversion = 0
	filemode = false
	bare = false
	logallrefupdates = true
	symlinks = false
	ignorecase = true
[submodule]
	active = .
[remote "origin"]
	url = https://github.com/yomihon/hoshidicts.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[branch "main-mit"]
	remote = origin
	merge = refs/heads/main-mit
[submodule "external/glaze"]
	url = https://github.com/stephenberry/glaze
[submodule "external/unordered_dense"]
	url = https://github.com/martinus/unordered_dense.git
[submodule "external/utfcpp"]
	url = https://github.com/nemtrif/utfcpp.git
[submodule "external/xxHash"]
	url = https://github.com/Cyan4973/xxHash.git
[submodule "external/zip"]
	url = https://github.com/kuba--/zip
[submodule "external/zstd"]
	url = https://github.com/facebook/zstd.git
